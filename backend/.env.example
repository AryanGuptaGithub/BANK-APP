# App
NODE_ENV=development
PORT=5000
APP_NAME=BankAPI

# MongoDB
MONGO_URI=mongodb://mongo:27017/bankdb

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=your_access_secret_change_in_production_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_change_in_production_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# Email (Nodemailer)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_pass
EMAIL_FROM=noreply@bankapi.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# MFA
MFA_APP_NAME=BankAPI

# Encryption (for sensitive data at rest — must be exactly 32 chars)
ENCRYPTION_KEY=your_32_char_encryption_key_here!
